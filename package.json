{
  "name": "right-answer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm --filter @right-answer/web dev\" \"pnpm --filter @right-answer/workers dev\"",
    "dev:db": "node scripts/start-local-postgres.mjs",
    "dev:qdrant": "node scripts/start-local-qdrant.mjs",
    "dev:web": "pnpm --filter @right-answer/web dev",
    "dev:api": "cargo run --manifest-path apps/api/Cargo.toml",
    "dev:workers": "pnpm --filter @right-answer/workers dev",
    "ops:status": "powershell -ExecutionPolicy Bypass -File scripts/show-runtime-status.ps1",
    "ops:status:logs": "powershell -ExecutionPolicy Bypass -File scripts/show-runtime-status.ps1 -IncludeLogs",
    "ops:db:check": "node scripts/check-db.mjs",
    "seed:export-postgres": "node scripts/export-postgres-seed.mjs",
    "build": "cargo build --manifest-path apps/api/Cargo.toml --release && pnpm --filter @right-answer/web build && pnpm --filter @right-answer/workers build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "textbook:extract-pages": "pnpm --filter @right-answer/api-node-legacy textbook:extract-pages",
    "textbook:detect-chapters": "pnpm --filter @right-answer/api-node-legacy textbook:detect-chapters",
    "textbook:ingest-local": "pnpm --filter @right-answer/api-node-legacy textbook:ingest-local",
    "textbook:run-all": "pnpm --filter @right-answer/api-node-legacy textbook:run-all",
    "textbook:batch-csv": "pnpm --filter @right-answer/api-node-legacy textbook:batch-csv",
    "db:generate": "pnpm --filter @right-answer/database prisma generate",
    "db:migrate": "pnpm --filter @right-answer/database prisma migrate dev",
    "db:deploy": "pnpm --filter @right-answer/database prisma migrate deploy",
    "db:seed": "pnpm --filter @right-answer/database seed"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@embedded-postgres/linux-x64",
      "@embedded-postgres/linux-arm64",
      "@embedded-postgres/linux-arm",
      "@embedded-postgres/darwin-x64",
      "@embedded-postgres/darwin-arm64",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.1",
    "embedded-postgres": "^18.4.0-beta.17",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
