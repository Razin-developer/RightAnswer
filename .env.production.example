POSTGRES_DB=right_answer
POSTGRES_USER=right_answer
POSTGRES_PASSWORD=change-this-long-random-postgres-password
JWT_SECRET=change-this-64-character-random-secret

# Replace example.com with your real domain.
DOMAIN=example.com
APP_URL=https://example.com
CORS_ORIGINS=https://example.com
VITE_API_URL=https://example.com/api

QDRANT_COLLECTION=right_answer_textbook_chunks

# Set one provider path.
AI_METHOD=openrouter
OPENROUTER_API_KEY=
HACKAI_API_KEY=
NVIDIA_API_KEY=

# gemma (default) or qwen — swaps default model names below; still routes
# through AI_METHOD's provider, no separate key needed.
AI_MODEL_FAMILY=gemma
AI_SIMPLE_MODEL=google/gemma-3-12b-it
AI_REASONING_MODEL=google/gemma-4-31b-it
AI_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b
AI_RERANK_MODEL=nvidia/rerank-qa-mistral-4b
# Reserved for when vision/image-input support lands — not used yet.
AI_VLM_THINKING_MODEL=qwen/qwen3-vl-8b-thinking
AI_VLM_INSTRUCT_MODEL=qwen/qwen3-vl-8b-instruct
SEMANTIC_CACHE_THRESHOLD=0.9

RUST_LOG=right_answer_api=info,tower_http=info
