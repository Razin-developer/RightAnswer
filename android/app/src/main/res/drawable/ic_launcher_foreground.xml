<?xml version="1.0" encoding="utf-8"?>
<!--
  RightAnswer brand mark — curved check with dot accent.

  108×108 dp adaptive-icon canvas.
  Safe zone: 72×72 dp centred (offset 18dp each side).
  Mark drawn within ~60% of safe zone, centred.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Left stroke  : (40.5, 55) → (48.5, 64)
      Curved stroke: quadratic bezier (48.5,64) ctrl(59,57) → (68,43)
    -->
    <path
        android:pathData="M40.5,55 L48.5,64 Q59,57 68,43"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4.2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- Dot accent at tip of the curved stroke (circle r=2.6 at 68,43) -->
    <path
        android:pathData="M68,43 m-2.6,0 a2.6,2.6 0 1,0 5.2,0 a2.6,2.6 0 1,0 -5.2,0"
        android:fillColor="#FFFFFF"/>

</vector>
