{
  "name": "@right-answer/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "format": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "textbook:extract-pages": "tsx scripts/textbook-extract-pages.ts",
    "textbook:detect-chapters": "tsx scripts/textbook-detect-chapters.ts",
    "textbook:ingest-local": "tsx scripts/textbook-ingest-local.ts",
    "textbook:run-all": "tsx scripts/textbook-run-all.ts",
    "textbook:batch-csv": "tsx scripts/textbook-batch-from-csv.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.2.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.16.2",
    "@right-answer/config": "workspace:*",
    "@right-answer/database": "workspace:*",
    "@right-answer/prompts": "workspace:*",
    "@right-answer/storage": "workspace:*",
    "@right-answer/types": "workspace:*",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.58.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fastify": "^5.6.0",
    "ioredis": "^5.7.0",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pdf-parse": "^1.1.4"
  }
}
