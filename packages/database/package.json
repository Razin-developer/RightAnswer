{
  "name": "@right-answer/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No tests for @right-answer/database')\"",
    "format": "prettier --check \"src/**/*.ts\" \"prisma/**/*.{prisma,sql,ts}\"",
    "prisma": "prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "prisma": "^6.16.2"
  }
}
