DATABASE_URL=postgresql://postgres:postgres@localhost:5432/right_answer
REDIS_URL=redis://localhost:6379
JWT_SECRET=right-answer-dev-secret
PORT=4000
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
VITE_API_URL=http://localhost:4000/api
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=right_answer_textbook_chunks

# Rust backend AI provider routing. Set AI_METHOD to hackai or openrouter.
AI_METHOD=openrouter
OPENROUTER_API_KEY=
HACKAI_API_KEY=
NVIDIA_API_KEY=
# AI_MODEL_FAMILY=gemma (default) or qwen. Only changes default model names
# below when the more specific AI_*_MODEL vars aren't set; no separate key
# needed since qwen still routes through AI_METHOD's provider.
AI_MODEL_FAMILY=gemma
AI_SIMPLE_MODEL=google/gemma-3-12b-it
AI_REASONING_MODEL=google/gemma-4-31b-it
AI_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b
AI_RERANK_MODEL=nvidia/rerank-qa-mistral-4b
# Not wired into any request yet (no image-input path exists) — reserved
# for when vision support lands.
AI_VLM_THINKING_MODEL=qwen/qwen3-vl-8b-thinking
AI_VLM_INSTRUCT_MODEL=qwen/qwen3-vl-8b-instruct
SEMANTIC_CACHE_THRESHOLD=0.9

# Optional provider keys. If these are missing, the app uses the local rule-based
# grounded answer composer and still preserves the cache-first and textbook-first flow.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

RIGHT_ANSWER_EMBEDDING_BACKEND=hf-transformers
RIGHT_ANSWER_EMBEDDING_MODEL=perplexity-ai/pplx-embed-v1-0.6b
RIGHT_ANSWER_EMBEDDING_DIMENSIONS=1024
RIGHT_ANSWER_EMBEDDING_MAX_LENGTH=512
RIGHT_ANSWER_EMBEDDING_BATCH_SIZE=48
RIGHT_ANSWER_EMBEDDING_THREADS=6
RIGHT_ANSWER_EMBEDDING_MAX_REQUESTS_PER_WORKER=8
RIGHT_ANSWER_EMBEDDING_ALLOW_FALLBACK=0
RIGHT_ANSWER_EMBEDDING_DEVICE=
RIGHT_ANSWER_QUERY_INSTRUCTION=
